{
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cn", "cva", "clsx", "twMerge"],
        "experimental": {
          "classRegex": [
            ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"],
            ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"],
            ["clsx\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"],
            ["twMerge\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"]
          ]
        }
      }
    }
  }
}
